{
  "name": "erp-mns",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run api\"",
    "setup": "bash scripts/dev-setup.sh",
    "setup:docker": "echo 'ยก MySQL ใน Docker สำหรับโหลด database/mns_pm_2021.sql' && docker compose up -d",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "npm run db:setup --prefix server",
    "db:generate": "npm run db:generate --prefix server",
    "db:validate": "npm run db:validate --prefix server",
    "db:push": "npm run db:push --prefix server",
    "prisma": "npm run prisma --prefix server --",
    "db:import-users": "npm run db:import-users --prefix server",
    "build": "tsc --noEmit && vite build && node --input-type=module -e \"import { copyFileSync } from 'node:fs'; copyFileSync('dist/index.html','dist/404.html');\"",
    "start": "node server/index.mjs",
    "preview": "vite preview",
    "preview:gh": "vite build && vite preview --base /mnserp/",
    "api": "npm run start --prefix server",
    "api:dev": "npm run dev --prefix server",
    "deploy:pack": "bash scripts/package-enhance-deploy.sh",
    "api:health": "node scripts/check-api-health.mjs",
    "verify:mysql-only": "node scripts/verify-mysql-only.mjs"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
