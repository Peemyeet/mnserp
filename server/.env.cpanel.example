# cPanel — คัดลอกเป็น server/.env แล้วแก้ค่าจริง
# รูปแบบ B: แยก DB_* (แนะนำ — ไม่ต้องใส่ DATABASE_URL ซ้ำ)
#
# API และ npm run db:generate จะประกอบ mysql:// จากค่าด้านล่างให้อัตโนมัติ

MNS_API_PORT=3000

# MySQL host ตามเซิร์ฟเวอร์ฐานข้อมูลจริง (ตัวอย่างโปรเจกต์นี้)
DB_HOST=27.254.151.80
DB_PORT=3306
# ถ้า import database/mns_pm_2021.sql ให้ตั้งชื่อฐานเป็น mns_pm_2021 (หรือให้ตรงกับ dump)
DB_DATABASE=ชื่อฐานที่สร้างใน_cPanel
DB_USERNAME=ชื่อ_MySQL_user
DB_PASSWORD=รหัสผ่าน

# ทางเลือก: ถ้าต้องการใส่ URL เต็มเอง (จะใช้แทนการประกอบจาก DB_*)
# DATABASE_URL=mysql://USER:PASSWORD@27.254.151.80:3306/ชื่อฐาน
