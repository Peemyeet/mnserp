# คัดลอกเป็น server/.env (โปรเจกต์นี้มี server/.env อยู่แล้ว — แก้รหัสผ่านให้ตรง MySQL)
#
# --- MySQL ติดตั้งบน Mac (เช่น MySQL Commercial installer) ---
# ใส่รหัส root ที่ตั้งในขั้น Configure ลงใน MNS_DB_PASSWORD แล้วรัน:  npm run db:setup
#
# --- หรือใช้ Docker ---
# npm run db:up  แล้วตั้ง  MNS_DB_PASSWORD=mns_dev_root

MNS_DB_HOST=127.0.0.1
MNS_DB_PORT=3306
MNS_DB_USER=root
MNS_DB_PASSWORD=
MNS_DB_NAME=db_mns

# พอร์ต Express — ต้องตรงกับ vite.config.ts proxy target
MNS_API_PORT=8787
